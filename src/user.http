### 1) Registro de usuario
POST http://localhost:3000/api/user/register
Content-Type: application/json

{
  "email": "prueba53@example.com",
  "password": "contrasenia123"
}

### 2) Validación de email
PUT http://localhost:3000/api/user/validation
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjY5Y2QzN2ZiMGM0NGIxYzVlY2I0ZWFiYiIsImlhdCI6MTc3NTA1Njg5MSwiZXhwIjoxNzc1MDU3NzkxfQ.6WcwrmiZKnnqTiiJoVg-4wixsNbkojpjvmcp23PC0Qo
Content-Type: application/json

{
  "code": "468084"
}

### 3) Login
POST http://localhost:3000/api/user/login
Content-Type: application/json

{
  "email": "prueba50@example.com",
  "password": "contrasenia123"
}

### 4) Onboarding: datos personales
PUT http://localhost:3000/api/user/register
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjY5Y2QzOTMwMGM0NGIxYzVlY2I0ZWFkZiIsImlhdCI6MTc3NTA1NzIwMCwiZXhwIjoxNzc1MDU4MTAwfQ.xWmCZoY9EmCZDA4OBpBtnD02CxLOY4WveKrSzq6ixlU
Content-Type: application/json

{
  "isFreelance": true,
  "name": "Juan",
  "lastName": "Pérez",
  "nif": "X1234567L"
}

### 5) Onboarding: datos de compañía
PATCH http://localhost:3000/api/user/company
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjY5Y2QzN2ZiMGM0NGIxYzVlY2I0ZWFiYiIsImlhdCI6MTc3NTA1NzAzNywiZXhwIjoxNzc1MDU3OTM3fQ.23m6ATShkFOsvzfcEpQWXLCySnBqGw70bcTUgQCRbAo
Content-Type: application/json

{
  "isFreelance": false,
  "name": "Empresa Juan",
  "lastName": "Pérez",
  "cif": "X1234567L",
  "address": {
    "street": "Calle Falsa",
    "number": "123",
    "postal": "28000",
    "city": "Madrid",
    "province": "Madrid"
  }
}

### 6) Obtener usuario
GET http://localhost:3000/api/user
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjY5Y2QzOTMwMGM0NGIxYzVlY2I0ZWFkZiIsImlhdCI6MTc3NTA1NzIwMCwiZXhwIjoxNzc1MDU4MTAwfQ.xWmCZoY9EmCZDA4OBpBtnD02CxLOY4WveKrSzq6ixlU
### 7) Cambiar contraseña
PUT http://localhost:3000/api/user/password
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjY5Y2QzN2ZiMGM0NGIxYzVlY2I0ZWFiYiIsImlhdCI6MTc3NTA1NzAzNywiZXhwIjoxNzc1MDU3OTM3fQ.23m6ATShkFOsvzfcEpQWXLCySnBqGw70bcTUgQCRbAo
Content-Type: application/json

{
  "currentPassword": "contrasenia123",
  "newPassword": "password456"
}

### 8) Invitar usuario
POST http://localhost:3000/api/user/invite
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjY5Y2QzOTMwMGM0NGIxYzVlY2I0ZWFkZiIsImlhdCI6MTc3NTA1NzIwMCwiZXhwIjoxNzc1MDU4MTAwfQ.xWmCZoY9EmCZDA4OBpBtnD02CxLOY4WveKrSzq6ixlU
Content-Type: application/json

{
  "email": "guest2@example.com",
  "name": "Invitado",
  "lastName": "Usuario"
}

### 9) Refresh token
POST http://localhost:3000/api/user/refresh
Content-Type: application/json

{
  "refreshToken": "544b0c04e2841e30b97f55b37a3637d33edf1c105e5eb3ef4e9a043f7a25241c9042726201ae7bd6317539663da58378b400739b08eedad8ff81d70936824e5a"
}

### 10) Logout
POST http://localhost:3000/api/user/logout
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjY5Y2QzOTMwMGM0NGIxYzVlY2I0ZWFkZiIsImlhdCI6MTc3NTA1NzIwMCwiZXhwIjoxNzc1MDU4MTAwfQ.xWmCZoY9EmCZDA4OBpBtnD02CxLOY4WveKrSzq6ixlU


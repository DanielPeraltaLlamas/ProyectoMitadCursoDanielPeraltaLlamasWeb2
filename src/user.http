{
  "code": "119628"
}

### 3) Login
POST http://localhost:3000/api/user/login
Content-Type: application/json

{
  "email": "prueba38@example.com",
  "password": "contrasenia123"
}

### 4) Onboarding: datos personales
PUT http://localhost:3000/api/user/register
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjY5ZDI2NGJhNDRmNWY2MWNlMjNmODEzMSIsImlhdCI6MTc3NTM5NjAyNiwiZXhwIjoxNzc1Mzk2OTI2fQ.B0B1Eis9AkloFSLfmx3v8tw41jHqbaVU3-TVOPtaj6Q
Content-Type: application/json

{
  "isFreelance": true,
  "name": "Juan",
  "lastName": "Pérez",
  "nif": "X1234567L"
}

### 5) Onboarding: datos de compañía
PATCH http://localhost:3000/api/user/company
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjY5ZWUxNzEzNGRkMGMxZjVjNTQzNzIzNiIsImlhdCI6MTc3NzIxMTE1NSwiZXhwIjoxNzc3MjEyMDU1fQ.tIu4K364amGu859ISSVjRc1gPpI6ziL55qP0ij30-dA
Content-Type: application/json

{
  "isFreelance": false,
  "name": "Empresa Juan",
  "lastName": "Pérez",
  "cif": "X12345676",
  "address": {
    "street": "Calle Falsa",
    "number": "123",
    "postal": "28000",
    "city": "Madrid",
    "province": "Madrid"
  }
}

### 6) Obtener usuario
GET http://localhost:3000/api/user
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjY5ZDI2NTkyZjQ5ODIzMjNmNzVhM2UzNCIsImlhdCI6MTc3NTM5NjI0MiwiZXhwIjoxNzc1Mzk3MTQyfQ.XYUauc2PE5NMiwXUSyPLGyRGxCmHrmGOIYcv7HM5scc
### 7) Cambiar contraseña
PUT http://localhost:3000/api/user/password
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjY5ZDI2NTkyZjQ5ODIzMjNmNzVhM2UzNCIsImlhdCI6MTc3NTM5NjI0MiwiZXhwIjoxNzc1Mzk3MTQyfQ.XYUauc2PE5NMiwXUSyPLGyRGxCmHrmGOIYcv7HM5scc
Content-Type: application/json

{
  "currentPassword": "contrasenia1234",
  "newPassword": "password456"
}

### 8) Invitar usuario
POST http://localhost:3000/api/user/invite
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjY5ZDI2NTkyZjQ5ODIzMjNmNzVhM2UzNCIsImlhdCI6MTc3NTM5NjI0MiwiZXhwIjoxNzc1Mzk3MTQyfQ.XYUauc2PE5NMiwXUSyPLGyRGxCmHrmGOIYcv7HM5scc
Content-Type: application/json

{
  "email": "guest4@example.com",
  "name": "Invitado",
  "lastName": "Usuario"
}

### 9) Refresh token
POST http://localhost:3000/api/user/refresh

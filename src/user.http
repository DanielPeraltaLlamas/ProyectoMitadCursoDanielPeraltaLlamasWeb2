### 1) Registro de usuario
POST http://localhost:3000/api/user/register
Content-Type: application/json

{
  "email": "prueba57@example.com",
  "password": "contrasenia123"
}

### 2) Validación de email
PUT http://localhost:3000/api/user/validation
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjY5Y2Q0MWFhZDc1YjQyZTllYmM5ZjNjMSIsImlhdCI6MTc3NTA1OTM3MCwiZXhwIjoxNzc1MDYwMjcwfQ.NpEA8Gis-t7dzowrU7zfYP_HPNehIT6gVxBjHYYyZew
Content-Type: application/json

{
  "code": "883038"
}

### 3) Login
POST http://localhost:3000/api/user/login
Content-Type: application/json

{
  "email": "prueba56@example.com",
  "password": "contrasenia123"
}

### 4) Onboarding: datos personales
PUT http://localhost:3000/api/user/register
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjY5Y2Q0MWFhZDc1YjQyZTllYmM5ZjNjMSIsImlhdCI6MTc3NTA1OTM3MCwiZXhwIjoxNzc1MDYwMjcwfQ.NpEA8Gis-t7dzowrU7zfYP_HPNehIT6gVxBjHYYyZew
Content-Type: application/json

{
  "isFreelance": true,
  "name": "Juan",
  "lastName": "Pérez",
  "nif": "X1234567L"
}

### 5) Onboarding: datos de compañía
PATCH http://localhost:3000/api/user/company
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjY5Y2Q0NjkwNGQxMTk2ZDVhNjI2N2MyNyIsImlhdCI6MTc3NTA2MDYyNCwiZXhwIjoxNzc1MDYxNTI0fQ.0KD4n9FIK8MSTI6Jee2qcRIpQqEgXqK3KVh8phNOm1M
Content-Type: application/json

{
  "isFreelance": false,
  "name": "Empresa Juan",
  "lastName": "Pérez",
  "cif": "X1234567M",
  "address": {
    "street": "Calle Falsa",
    "number": "123",
    "postal": "28000",
    "city": "Madrid",
    "province": "Madrid"
  }
}

### 6) Obtener usuario
GET http://localhost:3000/api/user
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjY5Y2Q0MWFhZDc1YjQyZTllYmM5ZjNjMSIsImlhdCI6MTc3NTA1OTM3MCwiZXhwIjoxNzc1MDYwMjcwfQ.NpEA8Gis-t7dzowrU7zfYP_HPNehIT6gVxBjHYYyZew
### 7) Cambiar contraseña
PUT http://localhost:3000/api/user/password
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjY5Y2Q0MWFhZDc1YjQyZTllYmM5ZjNjMSIsImlhdCI6MTc3NTA1OTM3MCwiZXhwIjoxNzc1MDYwMjcwfQ.NpEA8Gis-t7dzowrU7zfYP_HPNehIT6gVxBjHYYyZew
Content-Type: application/json

{
  "currentPassword": "contrasenia123",
  "newPassword": "password456"
}

### 8) Invitar usuario
POST http://localhost:3000/api/user/invite
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjY5Y2Q0MWFhZDc1YjQyZTllYmM5ZjNjMSIsImlhdCI6MTc3NTA1OTM3MCwiZXhwIjoxNzc1MDYwMjcwfQ.NpEA8Gis-t7dzowrU7zfYP_HPNehIT6gVxBjHYYyZew
Content-Type: application/json

{
  "email": "guest3@example.com",
  "name": "Invitado",
  "lastName": "Usuario"
}

### 9) Refresh token
POST http://localhost:3000/api/user/refresh
Content-Type: application/json

{
  "refreshToken": "544b0c04e2841e30b97f55b37a3637d33edf1c105e5eb3ef4e9a043f7a25241c9042726201ae7bd6317539663da58378b400739b08eedad8ff81d70936824e5a"
}

### 10) Logout
POST http://localhost:3000/api/user/logout
